# Nexus Oracle Updater Configuration
# Copy this file to .env and fill in your values

# RPC URL for the target network
# Polygon Amoy Testnet:
RPC_URL=https://rpc-amoy.polygon.technology

# Your wallet private key (with 0x prefix)
# WARNING: Never commit your actual private key!
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Deployed NexusRiskOracle contract address
ORACLE_ADDRESS=0xYOUR_ORACLE_ADDRESS_HERE
