# Nexus Protocol Configuration
# Copy to .env and fill in your values

# Your wallet private key (with 0x prefix)
# WARNING: Never commit this file with real keys
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polygon Amoy RPC URL
# Options:
#   - Public: https://rpc-amoy.polygon.technology
#   - Alchemy: https://polygon-amoy.g.alchemy.com/v2/YOUR_KEY
#   - Infura: https://polygon-amoy.infura.io/v3/YOUR_KEY
RPC_URL=https://rpc-amoy.polygon.technology
